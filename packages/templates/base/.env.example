# ──────────────────────────────────────────
# AI Provider Configuration
# ──────────────────────────────────────────

# Choose your provider: "anthropic" or "openai"
AI_PROVIDER=anthropic

# Chat model defaults (cost-efficient for MVP development).
# For higher quality at higher cost, consider:
#   anthropic: claude-opus-4-7
#   openai:    gpt-4o
AI_MODEL_CHAT=claude-sonnet-4-6
# AI_MODEL_CHAT=gpt-4o-mini

# Embedding model defaults.
AI_MODEL_EMBED=voyage-3
# AI_MODEL_EMBED=text-embedding-3-small

# ──────────────────────────────────────────
# API Keys
# ──────────────────────────────────────────

# Required if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Required if AI_PROVIDER=openai
OPENAI_API_KEY=

# ──────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────
# Stripe (if enabled)
# ──────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ──────────────────────────────────────────
# Resend (if enabled)
# ──────────────────────────────────────────
# RESEND_API_KEY=
