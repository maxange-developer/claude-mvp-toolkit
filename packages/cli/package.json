{
  "name": "@massiangelone/angel1-mvp-toolkit",
  "version": "1.0.0",
  "description": "Scaffold production-ready Next.js + Supabase apps with multi-provider AI (Claude, OpenAI, or both)",
  "license": "MIT",
  "author": "Massimiliano Angelone <massiangelone01@gmail.com>",
  "keywords": [
    "angel1",
    "mvp",
    "scaffold",
    "nextjs",
    "supabase",
    "anthropic",
    "claude",
    "openai",
    "gpt",
    "multi-provider",
    "ai-scaffold",
    "cli",
    "starter"
  ],
  "homepage": "https://github.com/maxange-developer/claude-mvp-toolkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxange-developer/claude-mvp-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/maxange-developer/claude-mvp-toolkit/issues"
  },
  "type": "module",
  "bin": {
    "angel1-mvp-toolkit": "dist/index.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "files": [
    "dist/",
    "templates/"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-templates.mjs",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "fs-extra": "^11.3.0",
    "ora": "^8.2.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.17.57",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
