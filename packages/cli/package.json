{
  "name": "@maxange/claude-mvp-toolkit",
  "version": "0.1.0-alpha",
  "description": "Scaffold production-ready Next.js + Supabase + Claude AI apps",
  "license": "MIT",
  "type": "module",
  "bin": {
    "claude-mvp-toolkit": "./dist/index.js"
  },
